{
  // ── File associations ─────────────────────────────────────────────────────
  // pfSense uses .inc for PHP include files; associate them with PHP so that
  // Intelephense, syntax highlighting, and formatters all activate correctly.
  // *_global_usage are plain-text Blacklist feed definitions (no extension).
  "files.associations": {
    "*.inc": "php",
    "*_global_usage": "plaintext"
  },

  // ── PHP (Intelephense) ────────────────────────────────────────────────────
  // pfSense CE 2.8 on FreeBSD 15 ships PHP 8.3.
  "intelephense.environment.phpVersion": "8.3",

  // stubs/pfsense/ contains hand-crafted declarations for pfSense functions,
  // globals, and constants.  Intelephense discovers them automatically via
  // workspace scanning — no explicit includePaths entry is required.
  //
  // Remaining "undefined" suppressions cover pfSense symbols that are not yet
  // in the stubs (add them to stubs/pfsense/ rather than expanding this list).
  "intelephense.diagnostics.undefinedFunctions": false,
  "intelephense.diagnostics.undefinedTypes": false,
  "intelephense.diagnostics.undefinedClassConstants": false,

  // ── Python ────────────────────────────────────────────────────────────────
  // testpaths and addopts are set in pyproject.toml; no path needed here.
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": [],
  // Pylance: standard mode surfaces common type errors; flip to "basic" if noisy.
  "python.analysis.typeCheckingMode": "standard",
  // Resolve imports that are not installed as packages:
  //  - stubs/python      holds unboundmodule.py, the dev/test stand-in for the
  //    symbols Unbound injects into pfb_unbound.py at runtime.
  //  - the pfblockerng pkg dir lets the tests' `import pfb_unbound` resolve.
  "python.analysis.extraPaths": [
    "stubs/python",
    "src/usr/local/pkg/pfblockerng"
  ],
  // maxminddb is resolved via stubs/python/maxminddb.pyi; the actual module is
  // provided by pfSense's py-maxminddb at runtime and is not installed in the
  // dev environment, so suppress the (expected) "missing source" notice.
  "python.analysis.diagnosticSeverityOverrides": {
    "reportMissingModuleSource": "none"
  },

  // ── Shell ─────────────────────────────────────────────────────────────────
  // ShellCheck auto-detects the shell dialect from each file's shebang line
  // (#!/bin/sh for POSIX sh, which is correct for all scripts in this repo).
  "shellcheck.run": "onSave",

  // ── Editor defaults ───────────────────────────────────────────────────────
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  // 120-column ruler matches the wide alignment style used in the PHP files.
  "editor.rulers": [120]
}
